# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored. Never commit the filled-in version.
# For Vercel, add each var via `vercel env add <NAME>` or the dashboard.

# --- Database (Neon) ---
# Pooled connection URL. Get from Neon console -> Connection Details.
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# --- Auth (Clerk) ---
# Publishable key is safe to expose (embedded in browser). Secret is not.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- Storage (Cloudflare R2, S3-compatible) ---
# From Cloudflare dashboard -> R2 -> Manage R2 API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=em2devs-apps-group-apartment-hunt
# Optional: if you enable public access or bind a custom domain, set the public URL base here.
# Example with r2.dev: https://pub-<hash>.r2.dev
# Example with custom domain: https://images.example.com
R2_PUBLIC_URL_BASE=

# --- Health endpoint auth ---
# Shared secret for Bearer-token access to /api/health/scrape (in addition
# to the Clerk session path). Generate with: openssl rand -hex 32
# Required in production and preview; recommended in development too so the
# 401 path is exercised.
HEALTH_AUTH_TOKEN=
